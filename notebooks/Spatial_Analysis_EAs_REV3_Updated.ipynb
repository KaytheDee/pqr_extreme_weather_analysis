   "execution_count": null,
   "id": "2c5f7032-454e-4c3d-825d-e507f3a4e8ea",
   "metadata": {},
   "outputs": [],
   "source": [
    "slope_fp = '/Users/kwamedonkor/Library/CloudStorage/OneDrive-UW/Quals/DEM/viz/viz.hh_slope.tif'\n",
    "\n",
    "slope_gh_da = rxr.open_rasterio(slope_fp, masked=True).squeeze()\n",
    "slope_gh_da = slope_gh_da.sel(x=slice(*x_bounds), y=slice(*y_bounds)) \n",
    "slope_gh_da = slope_gh_da.rio.reproject('EPSG:32630')"
   ]
  },
  {
   "cell_type": "code",
