   "metadata": {},
   "outputs": [],
   "source": [
    "stats_slope = zonal_stats(new_ea, saved_slope_fp, stats=[\"mean\"], raster_out=False)\n",
    "\n",
    "# Convert to Df & rename columns \n",
    "slope_df = pd.DataFrame(stats_slope).rename(columns={\"mean\":\"mean_slope\"})\n",
    "\n",
    "new_ea = new_ea.join(slope_df)"
   ]
