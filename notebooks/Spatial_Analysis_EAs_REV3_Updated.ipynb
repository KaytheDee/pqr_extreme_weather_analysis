    "    markersize=60, \n",
    "    label='Weather Station'\n",
    ")\n",
    "\n",
    "cbar = ax.get_figure().get_axes()[-1]  # usually the last axis is the colorbar\n",
    "cbar.set_ylabel(\"Mean Elevation (m)\", fontsize=14, fontweight='bold', labelpad = 15)\n",
    "\n",
