    "    'norm_pm2.5'\n",
    "]\n",
    "\n",
    "# Climate Vulnerability \n",
    "new_data_study_area['climate_vul_geo'] = new_data_study_area[cols_static_score].mean(axis=1, skipna=True)"
   ]
