  {
   "cell_type": "markdown",
   "id": "53404194-e174-4b23-892b-6aa709745ee7",
   "metadata": {},
   "source": [
    "### Normalizing Mean Elevation & Mean Slope "
   ]
  },
  {
   "cell_type": "markdown",
   "id": "afdf8bfd-4242-4d29-8fc9-718c315d3985",
   "metadata": {},
   "source": [
    "#### Normalize & invert --> so a high value indicates high flood risk "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4ce7334c-7667-435b-a8a5-fd98ff36de07",
   "metadata": {},
   "outputs": [],
   "source": [
    "# List of columns to transform\n",
    "\n",
    "cols = [\"mean_elev\", \"mean_slope\"]  "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "63571c47-ea66-4522-b4aa-340c0ee3490f",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Apply log10 normalization to multiple columns\n",
    "d = np.log10(new_ea[cols])\n",
    "\n",
    "# Normalize each column & invert \n",
    "log_df = 1 - (d - d.min()) / (d.max() - d.min())\n",
    "\n",
    "## rename columns \n",
    "\n",
    "for col in log_df.columns:\n",
    "    log_df[col + '_log_inverted'] = log_df[col]\n",
    "\n",
    "log_df = log_df.drop(columns=cols)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "14fc622c-6b04-49be-8673-db9fd9d13b3d",
   "metadata": {},
