   "source": [
    "### Air Quality  "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "89531c77-55df-4b71-982c-051a2645b1ea",
   "metadata": {},
   "outputs": [],
   "source": [
    "fp = '/Users/kwamedonkor/Library/CloudStorage/OneDrive-UW/Quals/Air_Quality/2022/GHAP_PM2.5_Y1K_2022_V1.nc'\n",
    "\n",
    "air_q_22_ds = xr.open_dataset(fp, engine=\"netcdf4\")\n",
    "\n",
    "lon_bounds = (-0.6, 0.1)\n",
    "lat_bounds = (6,5.4)\n",
    "\n",
    "air_q_subset_22 = air_q_22_ds.sel(\n",
    "    lon=slice(*lon_bounds),\n",
    "    lat=slice(*lat_bounds)\n",
    ")\n",
    "\n",
    "air_q_subset_22 = air_q_subset_22.rio.write_crs(\"EPSG:4326\")\n",
    "\n",
    "air_q_subset_22 = air_q_subset_22.rio.set_spatial_dims(x_dim=\"lon\", y_dim=\"lat\")\n",
    "\n",
    "air_q_utm_22 = air_q_subset_22.rio.reproject(\"EPSG:32630\")\n",
    "\n",
    "# Explicitly cast to float32 and set nodata to a float value (e.g., np.nan or -9999)\n",
    "air_q_utm_22['PM2.5'] = air_q_utm_22['PM2.5'].astype('float32')\n",
    "air_q_utm_22['PM2.5'].rio.write_nodata(np.nan, inplace=True)\n",
    "\n",
    "# Save with correct dtype\n",
    "air_q_utm_22['PM2.5'].rio.to_raster(\n",
    "    \"/Users/kwamedonkor/Library/CloudStorage/OneDrive-UW/Quals/Output_Files/aq_22_float.tif\",\n",
    "    dtype='float32'\n",
    ")\n",
    "\n",
    "# save to tif file \n",
    "saved_2022_aq_data_fp = \"/Users/kwamedonkor/Library/CloudStorage/OneDrive-UW/Quals/Output_Files/aq_22_float.tif\"\n",
    "\n",
    "stats_2022_aq = zonal_stats(new_ea, saved_2022_aq_data_fp, stats=[\"mean\"], raster_out=False, all_touched=True)\n",
    "\n",
    "# Convert to Df & rename columns \n",
    "aq_22_df = pd.DataFrame(stats_2022_aq).rename(columns={\"mean\":\"pm2.5_22\"})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7b7d82b0-82d2-4557-9693-a31024eb1afc",
   "metadata": {},
   "outputs": [],
   "source": [
    "ea_n_aq_22 = new_ea.join(aq_22_df)[['ea_code9ch', 'pm2.5_22']]\n",
    "\n",
    "ea_n_aq_22_filt = pd.merge(study_area, ea_n_aq_22, on = 'ea_code9ch', how = 'inner')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9a0705c0-61f0-4357-8882-39fb8fc8ab8a",
   "metadata": {},
   "outputs": [],
   "source": [
    "ea_n_aq_merged = ea_n_aq_22_filt.copy()\n",
    "\n",
    "cols_aq = ['pm2.5_22']\n",
    "\n",
    "# Mean Air_Quality  \n",
    "ea_n_aq_merged['pm2.5_mean'] = ea_n_aq_merged[cols_aq].mean(axis=1, skipna=True)\n",
    "\n",
    "## Normalize \n",
    "scaler = MinMaxScaler()\n",
    "ea_n_aq_merged['norm_pm2.5'] = scaler.fit_transform(ea_n_aq_merged[['pm2.5_mean']])\n",
    "\n",
    "ea_n_aq_merged = ea_n_aq_merged.set_index('ea_code9ch')"
   ]
  },
